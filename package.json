{
  "name": "@stocksharp/diagram",
  "version": "0.1.0",
  "description": "Browser strategy-diagram editor for StockSharp with typed ports, palette, canvas rendering, persistence, and a TypeScript API.",
  "license": "SEE LICENSE IN LICENSE",
  "author": {
    "name": "StockSharp Platform LLC",
    "url": "https://stocksharp.com/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/StockSharp/Diagram.git"
  },
  "homepage": "https://stocksharp.github.io/Diagram/",
  "bugs": {
    "url": "https://github.com/StockSharp/Diagram/issues"
  },
  "keywords": [
    "stocksharp",
    "diagram",
    "strategy",
    "trading",
    "algorithmic-trading",
    "node-editor",
    "visual-programming",
    "workflow",
    "typescript",
    "canvas"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/esm/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "unpkg": "./dist/ssdiagram.js",
  "jsdelivr": "./dist/ssdiagram.js",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js"
    },
    "./diagram": {
      "types": "./dist/types/diagram/stocksharp-diagram.d.ts",
      "import": "./dist/esm/diagram/stocksharp-diagram.js"
    },
    "./catalog": {
      "types": "./dist/types/diagram/catalog.d.ts",
      "import": "./dist/esm/diagram/catalog.js"
    },
    "./palette": {
      "types": "./dist/types/diagram/palette.d.ts",
      "import": "./dist/esm/diagram/palette.js"
    },
    "./types": {
      "types": "./dist/types/diagram/types.d.ts",
      "import": "./dist/esm/diagram/types.js"
    },
    "./document": {
      "types": "./dist/types/core/document.d.ts",
      "import": "./dist/esm/core/document.js"
    },
    "./state": {
      "types": "./dist/types/core/state.d.ts",
      "import": "./dist/esm/core/state.js"
    },
    "./view-state": {
      "types": "./dist/types/core/view-state.d.ts",
      "import": "./dist/esm/core/view-state.js"
    },
    "./history": {
      "types": "./dist/types/core/history.d.ts",
      "import": "./dist/esm/core/history.js"
    },
    "./actions": {
      "types": "./dist/types/core/action-registry.d.ts",
      "import": "./dist/esm/core/action-registry.js"
    },
    "./embed": {
      "types": "./dist/types/embed.d.ts",
      "import": "./dist/esm/embed.js"
    },
    "./source": "./src/index.ts",
    "./source/diagram": "./src/diagram/stocksharp-diagram.ts",
    "./source/catalog": "./src/diagram/catalog.ts",
    "./source/palette": "./src/diagram/palette.ts",
    "./source/types": "./src/diagram/types.ts",
    "./source/document": "./src/core/document.ts",
    "./source/state": "./src/core/state.ts",
    "./source/view-state": "./src/core/view-state.ts",
    "./source/history": "./src/core/history.ts",
    "./source/actions": "./src/core/action-registry.ts",
    "./source/embed": "./src/embed.ts"
  },
  "files": [
    "dist",
    "src",
    "LICENSE",
    "NOTICE",
    "README.md",
    "sample.png"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "node build.mjs",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "api:check": "node tools/check-public-api.mjs",
    "api:update": "node tools/check-public-api.mjs --update",
    "serve": "node serve.mjs",
    "build:tests": "node build-tests.mjs",
    "test": "npm run typecheck && npm run api:check && npm run build:tests && node --test \"tests/_dist/**/*.test.cjs\"",
    "test:browser": "npm run build && playwright test",
    "pack:check": "npm pack --dry-run",
    "release:check": "node tools/check-release-tag.mjs"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "^24.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.0"
  }
}
